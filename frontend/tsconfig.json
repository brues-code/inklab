{
    "compilerOptions": {
        "target": "ES2020",
        "useDefineForClassFields": true,
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "skipLibCheck": true,

        /* Bundler mode — Vite/esbuild handles emit; tsc is type-check only. */
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",

        /* Incremental adoption: JS and TS coexist. checkJs stays off so the
           existing .js/.jsx files aren't type-checked until each is converted
           and renamed to .ts/.tsx. Start loose; tighten in a later phase. */
        "allowJs": true,
        "checkJs": false,
        "strict": false,
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "noFallthroughCasesInSwitch": true
    },
    "include": ["src", "wailsjs"]
}
