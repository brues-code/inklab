# Binaries
*.exe
*.dll
*.so
*.dylib
bin/
dist/
build/bin/

# Go
vendor/

# Frontend
node_modules/
frontend/dist/
frontend/build/
frontend/node_modules/

# IDE
.vscode/
.idea/
*.swp
*.swo
InkLab.code-workspace

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Databases
*.db
!data/inklab.db
# SQLite runtime artifacts (never commit)
*.db-wal
*.db-shm
# Extracted-DB version marker (written at runtime next to the extracted db)
data/.dbversion

# Env (local secrets; commit .env.example instead)
.env

# Temp
*.tmp
*.bak
tmp/
.agent/

# Locally-generated zone maps (from client art; not shipped)
data/maps/
# Icons — extracted locally from client art / downloaded at runtime (not shipped)
data/icons/
# Reference JSON generated from the client DBCs (regenerated via the Import tab;
# the applied result already lives in the embedded inklab.db)
data/*.json
# NPC model/map images — built locally by syncing/scraping octowow.st (not shipped)
data/npc_images/
# Talent-frame background art — extracted locally from client art (not shipped)
data/talent_bg/
# Race/gender icons — cropped locally from the client sprite sheet (not shipped)
data/race_icons/
# Coin icons (gold/silver/copper) — cropped locally from UI-MoneyIcons (not shipped)
data/coin_icons/
# Per-chunk ADT area grid for spawn->zone resolution (regenerated via the Import tab)
data/area_grid.bin
